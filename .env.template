# Set to "true" only when Firebase emulators are running on your machine (Auth 9099, etc.).
# Leave unset or "false" to use your deployed project while developing (recommended with Blaze / deployed functions).
EXPO_PUBLIC_USE_FIREBASE_EMULATORS=""

# Firebase Configuration
EXPO_PUBLIC_FIREBASE_CONFIG_API_KEY=""
EXPO_PUBLIC_FIREBASE_CONFIG_AUTH_DOMAIN=""
EXPO_PUBLIC_FIREBASE_CONFIG_PROJECT_ID=""
EXPO_PUBLIC_FIREBASE_CONFIG_STORAGE_BUCKET=""
EXPO_PUBLIC_FIREBASE_CONFIG_MESSAGING_SENDER_ID=""
EXPO_PUBLIC_FIREBASE_CONFIG_APP_ID=""
EXPO_PUBLIC_FIREBASE_CONFIG_MEASUREMENT_ID=""

# Google Sign-In Client IDs (Web client ID = OAuth client_type 3 from google-services.json / Firebase Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=""
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=""
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=""

# Android native Google Sign-In: DEVELOPER_ERROR means Firebase/Google Cloud does not trust your app key.
# Add the debug keystore SHA-1 (and SHA-256) to Firebase Console → Project settings → Your Android app → Add fingerprint.
# Print fingerprints: cd android && ./gradlew signingReport   (use Variant: debug, Config: debug)
